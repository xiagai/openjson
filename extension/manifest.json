{
  "manifest_version": 3,
  "name": "JSON Formatter",
  "version": "1.0.0",
  "description": "Format and validate JSON instantly. Free, offline, no data upload.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["tabs", "clipboardWrite"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
